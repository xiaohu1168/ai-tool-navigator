import Database from "better-sqlite3";
import path from "path";

let _db: Database.Database | null = null;

export function getDb(): Database.Database {
  if (!_db) {
    const dbPath = path.join(process.cwd(), "prisma", "dev.db");
    _db = new Database(dbPath);
    _db.pragma("journal_mode = WAL");
    _db.pragma("foreign_keys = ON");
  }
  return _db;
}

export function resetDb(): void {
  if (_db) {
    _db.close();
    _db = null;
  }
}

export interface DbTool {
  id: string;
  slug: string;
  name: string;
  description: string;
  url: string;
  price: string;
  price_type: string;
  rating: number;
  featured: number;
  tags: string;
  pros: string;
  cons: string;
  for_whom: string;
  not_for: string;
  alternatives: string;
  privacy: string | null;
  updated: string | null;
  category_id: string;
  click_count: number;
  created_at: string;
  updated_at: string;
}

export interface DbCategory {
  id: string;
  slug: string;
  name: string;
  icon: string;
  description: string;
  count: number;
}

export interface DbSubmission {
  id: string;
  name: string;
  url: string;
  description: string;
  category_id: string;
  price: string | null;
  tags: string | null;
  status: string;
  created_at: string;
  updated_at: string;
}

export function getAllTools(): DbTool[] {
  return getDb().prepare("SELECT * FROM tools ORDER BY rating DESC").all() as DbTool[];
}

export function getToolsByCategory(categoryId: string): DbTool[] {
  return getDb().prepare("SELECT * FROM tools WHERE category_id = ? ORDER BY rating DESC").all(categoryId) as DbTool[];
}

export function getToolBySlug(slug: string): DbTool | undefined {
  return getDb().prepare("SELECT * FROM tools WHERE slug = ?").get(slug) as DbTool | undefined;
}

export function getFeaturedTools(count = 6): DbTool[] {
  return getDb().prepare("SELECT * FROM tools WHERE featured = 1 ORDER BY rating DESC LIMIT ?").all(count) as DbTool[];
}

export function searchTools(query: string): DbTool[] {
  if (!query) return getAllTools();
  const patterns = "%" + query + "%";
  return getDb().prepare(
    "SELECT * FROM tools WHERE name LIKE ? OR description LIKE ? OR tags LIKE ? ORDER BY rating DESC"
  ).all(patterns, patterns, patterns) as DbTool[];
}

export function getCategories(): DbCategory[] {
  return getDb().prepare("SELECT * FROM categories ORDER BY name").all() as DbCategory[];
}

export function getSubmissions(): DbSubmission[] {
  return getDb().prepare("SELECT * FROM submissions ORDER BY created_at DESC").all() as DbSubmission[];
}

export function addSubmission(data: { name: string; url: string; description: string; category_id: string; price?: string; tags?: string }): string {
  const id = Math.random().toString(36).slice(2, 10);
  const now = new Date().toISOString();
  getDb().prepare(
    "INSERT INTO submissions (id, name, url, description, category_id, price, tags, status, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, 'pending', ?, ?)"
  ).run(id, data.name, data.url, data.description, data.category_id, data.price || null, data.tags || null, now, now);
  return id;
}

export function updateSubmissionStatus(id: string, status: "approved" | "rejected") {
  getDb().prepare("UPDATE submissions SET status = ?, updated_at = ? WHERE id = ?").run(status, new Date().toISOString(), id);
}

export function incrementToolClick(slug: string) {
  getDb().prepare("UPDATE tools SET click_count = click_count + 1 WHERE slug = ?").run(slug);
}

export function getToolClicks(): { slug: string; count: number }[] {
  return getDb().prepare("SELECT slug, click_count as count FROM tools ORDER BY click_count DESC LIMIT 50").all() as { slug: string; count: number }[];
}

export function addPageView(data: { path: string; referrer?: string; ip?: string; user_agent?: string }) {
  const id = Math.random().toString(36).slice(2, 10);
  getDb().prepare(
    "INSERT INTO page_views (id, path, referrer, ip, user_agent, timestamp) VALUES (?, ?, ?, ?, ?, datetime('now'))"
  ).run(id, data.path, data.referrer || null, data.ip || null, data.user_agent || null);
}

export function addSearchQuery(query: string, results: number) {
  const id = Math.random().toString(36).slice(2, 10);
  getDb().prepare(
    "INSERT INTO search_queries (id, query, results, timestamp) VALUES (?, ?, ?, datetime('now'))"
  ).run(id, query, results);
}

export function getPageStats() {
  const views = getDb().prepare("SELECT COUNT(*) as total FROM page_views").get() as { total: number };
  const tools = getToolClicks();
  const queries = getDb().prepare("SELECT query, COUNT(*) as cnt FROM search_queries GROUP BY query ORDER BY cnt DESC LIMIT 50").all() as { query: string; cnt: number }[];
  return { total_views: views.total, tool_clicks: tools, search_queries: queries.map(q => ({ query: q.query, count: q.cnt })) };
}

// --- Blog Post CRUD ---
export interface DbBlogPost {
  id: string;
  slug: string;
  title: string;
  content: string;
  category: string;
  date: string;
  views: number;
  created_at: string;
  updated_at: string;
}

export function getBlogPosts(): DbBlogPost[] {
  return getDb().prepare("SELECT * FROM blog_posts ORDER BY date DESC").all() as DbBlogPost[];
}

export function getBlogPostBySlug(slug: string): DbBlogPost | undefined {
  return getDb().prepare("SELECT * FROM blog_posts WHERE slug = ?").get(slug) as DbBlogPost | undefined;
}

export function addBlogPost(data: { title: string; content: string; category: string; date: string }): string {
  const id = Math.random().toString(36).slice(2, 10);
  const now = new Date().toISOString();
  getDb().prepare(
    "INSERT INTO blog_posts (id, slug, title, content, category, date, views, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, 0, ?, ?)"
  ).run(id, data.title.toLowerCase().replace(/\s+/g, "-").replace(/[^a-z0-9-]/g, ""), data.title, data.content, data.category, data.date, now, now);
  return id;
}

export function updateBlogPost(slug: string, data: Partial<{ title: string; content: string; category: string; date: string }>) {
  const sets: string[] = [];
  const vals: any[] = [];
  if (data.title) { sets.push("title = ?"); vals.push(data.title); }
  if (data.content) { sets.push("content = ?"); vals.push(data.content); }
  if (data.category) { sets.push("category = ?"); vals.push(data.category); }
  if (data.date) { sets.push("date = ?"); vals.push(data.date); }
  sets.push("updated_at = datetime('now')");
  vals.push(slug);
  getDb().prepare("UPDATE blog_posts SET " + sets.join(", ") + " WHERE slug = ?").run(...vals);
}

export function deleteBlogPost(slug: string) {
  getDb().prepare("DELETE FROM blog_posts WHERE slug = ?").run(slug);
}

export function incrementBlogPostViews(slug: string) {
  getDb().prepare("UPDATE blog_posts SET views = views + 1 WHERE slug = ?").run(slug);
}


// --- Affiliate Link CRUD ---
export interface DbAffiliateLink {
  id: string;
  tool_id: string;
  label: string;
  url: string;
  network: string;
  click_count: number;
  created_at: string;
  updated_at: string;
}

export function getAffiliateLinksByTool(toolId: string): DbAffiliateLink[] {
  return getDb().prepare("SELECT * FROM affiliate_links WHERE tool_id = ? ORDER BY click_count DESC").all(toolId) as DbAffiliateLink[];
}

export function addAffiliateLink(data: { tool_id: string; label: string; url: string; network: string }): string {
  const id = Math.random().toString(36).slice(2, 10);
  const now = new Date().toISOString();
  getDb().prepare(
    "INSERT INTO affiliate_links (id, tool_id, label, url, network, click_count, created_at, updated_at) VALUES (?, ?, ?, ?, ?, 0, ?, ?)"
  ).run(id, data.tool_id, data.label, data.url, data.network, now, now);
  return id;
}

export function trackAffiliateClick(linkId: string) {
  getDb().prepare("UPDATE affiliate_links SET click_count = click_count + 1 WHERE id = ?").run(linkId);
}

// --- Prompt CRUD ---
export interface DbPrompt {
  id: string;
  tool_id: string;
  title: string;
  prompt_text: string;
  use_case: string;
  best_model: string | null;
  copy_count: number;
  created_at: string;
  updated_at: string;
}

export function getPromptsByTool(toolId: string): DbPrompt[] {
  return getDb().prepare("SELECT * FROM prompts WHERE tool_id = ? ORDER BY copy_count DESC").all(toolId) as DbPrompt[];
}

export function addPrompt(data: { tool_id: string; title: string; prompt_text: string; use_case: string; best_model?: string }): string {
  const id = Math.random().toString(36).slice(2, 10);
  const now = new Date().toISOString();
  getDb().prepare(
    "INSERT INTO prompts (id, tool_id, title, prompt_text, use_case, best_model, copy_count, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, 0, ?, ?)"
  ).run(id, data.tool_id, data.title, data.prompt_text, data.use_case, data.best_model || null, now, now);
  return id;
}

export function trackPromptCopy(promptId: string) {
  getDb().prepare("UPDATE prompts SET copy_count = copy_count + 1 WHERE id = ?").run(promptId);
}

// --- Compare Page CRUD ---
export interface DbComparePage {
  id: string;
  slug: string;
  tool1_id: string;
  tool2_id: string;
  title: string;
  content: string;
  views: number;
  created_at: string;
  updated_at: string;
}

export function getComparePageBySlug(slug: string): DbComparePage | undefined {
  try {
    return getDb().prepare("SELECT * FROM compare_pages WHERE slug = ?").get(slug) as DbComparePage | undefined;
  } catch {
    return undefined;
  }
}

export function getAllComparePages(): DbComparePage[] {
  return getDb().prepare("SELECT * FROM compare_pages ORDER BY created_at DESC").all() as DbComparePage[];
}

export function addComparePage(data: { slug: string; tool1_id: string; tool2_id: string; title: string; content: string }): string {
  const id = Math.random().toString(36).slice(2, 10);
  const now = new Date().toISOString();
  getDb().prepare(
    "INSERT INTO compare_pages (id, slug, tool1_id, tool2_id, title, content, views, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, 0, ?, ?)"
  ).run(id, data.slug, data.tool1_id, data.tool2_id, data.title, data.content, now, now);
  return id;
}

export function incrementComparePageViews(slug: string) {
  getDb().prepare("UPDATE compare_pages SET views = views + 1 WHERE slug = ?").run(slug);
}
