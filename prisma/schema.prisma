generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  email        String    @unique
  passwordHash String
  role         String    @default("ADMIN")
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("User")
}

model FailedLoginAttempt {
  id        String   @id @default(cuid())
  username  String
  ip        String?
  timestamp DateTime @default(now())

  @@map("FailedLoginAttempt")
}

model Tool {
  id              String          @id @default(cuid())
  slug            String          @unique
  name            String
  description     String
  url             String
  affiliate_url   String          @default("")
  price           String
  price_type      String          @default("Free")
  rating          Float           @default(4.0)
  featured        Boolean         @default(false)
  tags            String[]
  pros            String[]
  cons            String[]
  for_whom        String
  not_for         String
  alternatives    String
  privacy         String?
  updated         String?
  category_id     String
  click_count     Int             @default(0)
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt
  affiliate_links AffiliateLink[]
  prompts         Prompt[]
  category        Category        @relation(fields: [category_id], references: [id])

  @@map("Tool")
}

model Category {
  id          String @id @default(cuid())
  slug        String @unique
  name        String
  icon        String
  description String
  count       Int    @default(0)
  tools       Tool[]

  @@map("Category")
}

model Submission {
  id          String   @id @default(cuid())
  name        String
  url         String
  description String
  category_id String
  price       String?
  tags        String?
  status      String   @default("pending")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("Submission")
}

model BlogPost {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String
  content    String
  category   String
  date       String
  views      Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("BlogPost")
}

model SearchQuery {
  id        String   @id @default(cuid())
  query     String
  results   Int      @default(0)
  timestamp DateTime @default(now())

  @@map("SearchQuery")
}

model PageView {
  id         String   @id @default(cuid())
  path       String
  referrer   String?
  ip         String?
  user_agent String?
  timestamp  DateTime @default(now())

  @@map("PageView")
}

model AdPerformance {
  id          String   @id @default(cuid())
  slot        String
  impressions Int      @default(0)
  clicks      Int      @default(0)
  date        String
  created_at  DateTime @default(now())

  @@unique([slot, date])
  @@map("AdPerformance")
}

model AffiliateLink {
  id          String   @id @default(cuid())
  tool_id     String
  label       String
  url         String
  network     String
  click_count Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  tool        Tool     @relation(fields: [tool_id], references: [id])

  @@map("AffiliateLink")
}

model Prompt {
  id          String   @id @default(cuid())
  tool_id     String
  title       String
  prompt_text String
  use_case    String
  best_model  String?
  copy_count  Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  tool        Tool     @relation(fields: [tool_id], references: [id])

  @@map("Prompt")
}

model ComparePage {
  id         String   @id @default(cuid())
  slug       String   @unique
  tool1_id   String
  tool2_id   String
  title      String
  content    String
  views      Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("ComparePage")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  created_at DateTime @default(now())

  @@map("NewsletterSubscriber")
}
